# Supabase keys (FINDING-03 naming): the new CLI emits sb_publishable_... and sb_secret_...
#   - sb_publishable_...: modern publishable key, safe for the frontend. The current Supabase
#     local stack uses a shared default (not a secret).
#   - VITE_SUPABASE_ANON_KEY (below) is the template's LEGACY variable name. This does NOT mean
#     "anon" and "publishable" are identical: the legacy field ACCEPTS your
#     modern publishable key (paste the sb_publishable_... value there).
#   - sb_secret_... / service_role: server only. Never put it in VITE_* or in the bundle.
VITE_BACKEND_PROVIDER=SUPABASE
VITE_AUTH_MODE=MAGIC_LINK
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
