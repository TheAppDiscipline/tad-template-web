{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.local/schemas/<feature_name>.schema.json",
    "title": "<feature_name> Response Schema",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "schema_version",
        "request_id",
        "ok",
        "data",
        "error"
    ],
    "properties": {
        "schema_version": {
            "type": "string",
            "description": "Schema version for compatibility",
            "pattern": "^v\\d+(\\.\\d+)?$"
        },
        "request_id": {
            "type": "string",
            "minLength": 1
        },
        "ok": {
            "type": "boolean"
        },
        "data": {
            "$ref": "#/$defs/Data"
        },
        "error": {
            "$ref": "#/$defs/Error"
        }
    },
    "$defs": {
        "Error": {
            "type": [
                "object",
                "null"
            ],
            "additionalProperties": false,
            "required": [
                "code",
                "message",
                "missing_fields",
                "retryable"
            ],
            "properties": {
                "code": {
                    "type": "string",
                    "enum": [
                        "NONE",
                        "MISSING_FIELDS",
                        "AMBIGUOUS",
                        "INVALID_INPUT",
                        "POLICY_BLOCK",
                        "PROVIDER_ERROR",
                        "INTERNAL_ERROR"
                    ]
                },
                "message": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 400
                },
                "missing_fields": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "maxItems": 20
                },
                "retryable": {
                    "type": "boolean"
                }
            }
        },
        "Data": {
            "type": [
                "object",
                "null"
            ],
            "additionalProperties": false,
            "description": "TODO: Replace this with the real shape of your feature.",
            "required": [],
            "properties": {}
        }
    },
    "allOf": [
        {
            "$comment": "Success: data MUST be present (non-null), the error code MUST be NONE and the message MUST be \"ok\" (never empty, never prose).",
            "if": {
                "properties": {
                    "ok": {
                        "const": true
                    }
                }
            },
            "then": {
                "properties": {
                    "data": {
                        "type": "object"
                    },
                    "error": {
                        "type": "object",
                        "properties": {
                            "code": {
                                "const": "NONE"
                            },
                            "message": {
                                "const": "ok"
                            }
                        },
                        "required": [
                            "code",
                            "message"
                        ]
                    }
                },
                "required": [
                    "data"
                ]
            }
        },
        {
            "$comment": "Failure: data MUST be null and the error code MUST NOT be NONE.",
            "if": {
                "properties": {
                    "ok": {
                        "const": false
                    }
                }
            },
            "then": {
                "properties": {
                    "data": {
                        "type": "null"
                    },
                    "error": {
                        "type": "object",
                        "properties": {
                            "code": {
                                "not": {
                                    "const": "NONE"
                                }
                            }
                        },
                        "required": [
                            "code"
                        ]
                    }
                },
                "required": [
                    "error"
                ]
            }
        },
        {
            "$comment": "retryable is true ONLY for transient errors. Every other code (including NONE) is false: they need a changed input, not a blind retry.",
            "if": {
                "required": [
                    "error"
                ],
                "properties": {
                    "error": {
                        "type": "object",
                        "required": [
                            "code"
                        ],
                        "properties": {
                            "code": {
                                "enum": [
                                    "PROVIDER_ERROR",
                                    "INTERNAL_ERROR"
                                ]
                            }
                        }
                    }
                }
            },
            "then": {
                "properties": {
                    "error": {
                        "properties": {
                            "retryable": {
                                "const": true
                            }
                        }
                    }
                }
            },
            "else": {
                "properties": {
                    "error": {
                        "properties": {
                            "retryable": {
                                "const": false
                            }
                        }
                    }
                }
            }
        },
        {
            "$comment": "missing_fields is non-empty ONLY for MISSING_FIELDS; empty for every other code.",
            "if": {
                "required": [
                    "error"
                ],
                "properties": {
                    "error": {
                        "type": "object",
                        "required": [
                            "code"
                        ],
                        "properties": {
                            "code": {
                                "const": "MISSING_FIELDS"
                            }
                        }
                    }
                }
            },
            "then": {
                "properties": {
                    "error": {
                        "properties": {
                            "missing_fields": {
                                "minItems": 1
                            }
                        }
                    }
                }
            },
            "else": {
                "properties": {
                    "error": {
                        "properties": {
                            "missing_fields": {
                                "maxItems": 0
                            }
                        }
                    }
                }
            }
        }
    ]
}