{
  "name": "tad-template-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheAppDiscipline/tad-template-web.git"
  },
  "homepage": "https://github.com/TheAppDiscipline/tad-template-web#readme",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node --test tests/tooling.test.js tests/tooling.discipline.test.js",
    "check-tokens": "node tools/check_no_hex_colors.js",
    "check-secrets": "node tools/check_no_secrets_in_frontend.js",
    "check-bundle": "node tools/check_bundle_size.js",
    "check-rls": "node tools/check_rls.js",
    "check-cors": "node tools/check_cors.js",
    "check-https": "node tools/check_https_redirect.js",
    "check-magic": "node tools/check_magic_numbers.js",
    "check-magic:strict": "node tools/check_magic_numbers.js --strict",
    "check-queries": "node tools/check_query_limits.js",
    "check-queries:strict": "node tools/check_query_limits.js --strict",
    "check-fk-indexes": "node tools/check_fk_indexes.js",
    "check-db-types": "node tools/check_db_types.js",
    "check-db-types:strict": "node tools/check_db_types.js --strict",
    "migration:lint": "node tools/migration_lint.js",
    "check-firebase": "node tools/check_firebase_rules.js",
    "audit:high": "node tools/check_audit.js",
    "gate": "npm run lint && tsc -p tsconfig.app.json --noEmit && npm run test && npm run check-tokens && npm run check-secrets && npm run check-rls && npm run check-cors && npm run check-https && npm run check-fk-indexes && npm run migration:lint && npm run check-firebase",
    "gate:full": "npm run gate && npm run check-bundle && npm run check-magic && npm run check-queries && npm run ai:eval",
    "gate:strict": "npm run gate && npm run check-magic:strict && npm run check-queries:strict && npm run check-db-types:strict",
    "gate:launch": "npm run gate:strict && npm run discipline:validate:launch && npm run test:rls && npm run test:storage:privacy && npm run audit:high",
    "test:rls": "node tests/rls/cross-space.mjs",
    "test:storage:privacy": "node tests/storage/private-access.mjs",
    "backend:smoke": "node tools/backend_smoke_test.js",
    "db:smoke": "node tools/supabase_smoke_test.js",
    "db:types:generate": "node tools/generate_db_types.js",
    "firebase:smoke": "node tools/firebase_smoke_test.js",
    "ai:smoke": "node tools/llm_smoke_test.js",
    "ai:eval": "node tools/llm_eval.js --mode=fixture",
    "discipline:hydrate": "tsx tools/discipline/hydrate-template.ts",
    "discipline:patch": "tsx tools/discipline/apply-patch.ts",
    "discipline:patch:dry-run": "tsx tools/discipline/apply-patch.ts --dry-run",
    "discipline:assemble": "tsx tools/discipline/assemble-paste-ready.ts",
    "discipline:progress": "tsx tools/discipline/update-progress.ts",
    "discipline:log": "tsx tools/discipline/log-run.ts",
    "discipline:validate": "tsx tools/discipline/validate-discipline.ts",
    "discipline:validate:launch": "tsx tools/discipline/validate-scorecard.ts --mode=launch",
    "discipline:validate:prod": "tsx tools/discipline/validate-scorecard.ts --mode=prod",
    "discipline:validate:scope": "tsx tools/discipline/validate-scope.ts",
    "discipline:validate:architecture": "tsx tools/discipline/validate-architecture.ts",
    "discipline:doctor": "tsx tools/discipline/doctor.ts",
    "discipline:release-pack": "tsx tools/discipline/release-pack.ts",
    "discipline:cross-validate": "tsx tools/discipline/cross-validate.ts",
    "discipline:cross-validate:live": "tsx tools/discipline/cross-validate.ts --live",
    "discipline:status": "tsx tools/discipline/validate-discipline.ts --status",
    "discipline:watch": "tsx tools/discipline/watch.ts",
    "discipline:step1-prep": "tsx tools/discipline/step1-prep.ts",
    "discipline:ai-scaffold": "tsx tools/discipline/ai-scaffold.ts",
    "discipline:test-scaffold": "tsx tools/discipline/test-scaffold.ts",
    "discipline:audit-merge": "tsx tools/discipline/audit-merge.ts",
    "discipline": "tsx tools/discipline/cli.ts",
    "deploy:preview": "vercel",
    "deploy:prod": "vercel --prod",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "test:a11y": "playwright test --config playwright.a11y.config.ts",
    "gate:visual": "node tools/run_visual_e2e.mjs",
    "discipline:rls-generate": "node tools/generate_rls.js",
    "verify:deploy": "playwright test tests/e2e/verify-deploy.spec.ts"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.59.1",
    "@types/js-yaml": "^4.0.9",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.3.5",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.2.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "axe-core": "^4.10.0",
    "chokidar": "^4.0.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.39.3",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "js-yaml": "^4.1.0",
    "minimist": "^1.2.8",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.9"
  },
  "engines": {
    "node": ">=22"
  },
  "engineStrict": true
}
