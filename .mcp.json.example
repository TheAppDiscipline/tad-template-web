{
  "_README": "Copy this file to .mcp.json in your repo. Do not commit it; .gitignore covers it. Keep only the servers you actually use. Any server prefixed with _DISABLED_ is off by default; rename it by removing _DISABLED_ and fill in credentials to enable it. See CLAUDE.md for setup details. The complete The App Discipline vault is sold separately.",
  "_DOC_LINK": "https://docs.claude.com/en/docs/claude-code/mcp",
  "_LEAST_PRIVILEGE_RULE": "Every credential must be read-only until the task explicitly requires write access. Never paste SERVICE_ROLE_KEY values or broad write-scope tokens here.",

  "mcpServers": {
    "github": {
      "_purpose": "Read pull requests, issues, releases, and CI status without leaving Claude Code context. Use a read-only PAT when possible (scopes: repo:read or public_repo).",
      "command": "npx",
      "args": ["-y", "@anthropic-ai/github-mcp"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_replace-with-read-only-PAT"
      }
    },

    "playwright": {
      "_purpose": "Debug the browser when needed: capture screenshots, run selectors, and inspect HTML for UI diagnosis. No credentials required.",
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },

    "_DISABLED_supabase": {
      "_purpose": "Read tables, RLS policies, and migrations in read-only mode. Useful for Step 2 architecture validation and RLS audits. To enable it, remove _DISABLED_, install @supabase/mcp-server, and configure SUPABASE_URL plus SUPABASE_ANON_KEY. Never use service_role here.",
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server"],
      "env": {
        "SUPABASE_URL": "https://your-project.supabase.co",
        "SUPABASE_ANON_KEY": "<your-supabase-anon-key>"
      }
    },

    "_DISABLED_sentry": {
      "_purpose": "Read Sentry issues, releases, and performance metrics. Useful for Step 6 post-deploy verification and performance review. Use a token with project:read scope.",
      "command": "npx",
      "args": ["-y", "@sentry/mcp-server"],
      "env": {
        "SENTRY_AUTH_TOKEN": "sntrys_replace-with-read-only-token",
        "SENTRY_ORG": "your-org-slug",
        "SENTRY_PROJECT": "your-project-slug"
      }
    },

    "_DISABLED_posthog": {
      "_purpose": "Read PostHog events, funnels, and dashboards. Useful for Step 7 product decisions based on real usage. Use a personal API key with read-only access.",
      "command": "npx",
      "args": ["-y", "@posthog/mcp-server"],
      "env": {
        "POSTHOG_PROJECT_API_KEY": "phx_replace-with-personal-api-key",
        "POSTHOG_HOST": "https://us.i.posthog.com"
      }
    },

    "_DISABLED_stripe": {
      "_purpose": "Read customers, subscriptions, and invoices. Useful for Step 7 monetization checks and billing diagnostics. Use a restricted key with read access only.",
      "command": "npx",
      "args": ["-y", "@stripe/mcp-server"],
      "env": {
        "STRIPE_SECRET_KEY": "rk_live_replace-with-restricted-key-read-only"
      }
    }
  }
}
